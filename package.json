{
  "name": "slack-bot",
  "version": "1.0.0",
  "description": "Slack Bot",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "worker:awareness": "node src/workers/startAwarenessWorker.js",
